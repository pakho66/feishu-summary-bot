# 环境变量配置模板
# 复制此文件为 .env 并填写真实值

# 飞书配置（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERIFICATION_TOKEN=your-verification-token-123

# OpenAI 配置（可选，用于 AI 智能总结）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 用户配置（可选，用于定时发送）
USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxx

# 服务器配置
PORT=3000
NODE_ENV=development
